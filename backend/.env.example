# FleetOps Backend - Environment Variables
# Copy this file to .env and fill in the values

# Database
DATABASE_URL="postgresql://fleetops:fleetops_pass@localhost:5432/fleetops_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# Telegram Bot (optional - system works without it, errors are logged)
TELEGRAM_BOT_TOKEN="8482879639:AAG7Mdcxfuzfxvf2sxYO-c5wyZo65fjNaIQ"
TELEGRAM_CHAT_ID="6684996248"

# Frontend URL (for password reset emails in the future)
FRONTEND_URL="http://localhost:5173"
